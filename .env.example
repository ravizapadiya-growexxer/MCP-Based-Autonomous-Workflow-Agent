# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://your-company.atlassian.net
JIRA_USERNAME=your.email@company.com
JIRA_API_TOKEN=                              # Or: keyring.set_password('mcp-agent','JIRA_API_TOKEN','...')
JIRA_PROJECT_KEY=DEV
JIRA_ASSIGNEE_ACCOUNT_ID=                    # Your Jira accountId — see profile URL

# Find these with: make list-transitions (run against any existing issue in your project)
JIRA_IN_PROGRESS_TRANSITION_ID=21
JIRA_DONE_TRANSITION_ID=31

STORY_ESTIMATE_HOURS=8
JIRA_ASSIGNEE_NAME=ravi_zapadiya                 # Used for subtask title: ravi_zapadiya - [date] Daily Development Work

# ── Timesheet Portal ──────────────────────────────────────────────────────────
TIMESHEET_URL=https://timesheet.yourcompany.com
TIMESHEET_USERNAME=your.username
TIMESHEET_PASSWORD=                          # Or: keyring.set_password('mcp-agent','TIMESHEET_PASSWORD','...')
TIMESHEET_SYNC_BUTTON_TEXT=Sync             # Exact label of the Sync button

# Override selectors if your portal uses non-standard field names
# TS_USERNAME_SELECTOR=input[name='username'], input[type='email']
# TS_PASSWORD_SELECTOR=input[name='password'], input[type='password']
# TS_LOGIN_BUTTON_SELECTOR=button[type='submit']

# ── User ──────────────────────────────────────────────────────────────────────
USER_EMAIL=creatorx1235@gmail.com

# ── Scheduler ─────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata
MORNING_HOUR=11
MORNING_MINUTE=0
EVENING_HOUR=19
EVENING_MINUTE=0

# ── Browser ───────────────────────────────────────────────────────────────────
BROWSER_HEADLESS=true                        # false = show browser window (useful for debugging)

# ── WhatsApp — CallMeBot (Free) ───────────────────────────────────────────────
# Setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE=+91XXXXXXXXXX                # With country code
WHATSAPP_APIKEY=                            # Provided by CallMeBot after activation

# ── WhatsApp — Twilio (Premium, optional) ─────────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Behavior ──────────────────────────────────────────────────────────────────
DRY_RUN=false                               # true = log only, no Jira/browser changes
REQUIRE_HUMAN_APPROVAL=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG, INFO, WARNING, ERROR
LOG_DIR=logs

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/agent.db

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8000
