# ─── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=                           # id.atlassian.com -> Security -> API Tokens

# ─── Jira workflow config ─────────────────────────────────────────────────────
JIRA_PARENT_KEY=PROJ-100
JIRA_PROJECT_KEY=PROJ
MY_JIRA_LABEL=ravi-zapadiya
MY_USERNAME_PREFIX=ravi_zapadiya

# ─── Timesheet portal ─────────────────────────────────────────────────────────
TIMESHEET_URL=https://timesheet.yourcompany.com
TIMESHEET_USERNAME=you
TIMESHEET_PASSWORD=

# ─── Twilio (WhatsApp + SMS) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+14155238886           # Twilio sandbox or your number
TWILIO_TO_NUMBER=+919xxxxxxxxx            # E.164 format
TWILIO_CHANNEL=whatsapp                   # whatsapp | sms

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ─── Application ──────────────────────────────────────────────────────────────
STATE_DB_PATH=data/automation_state.db
INTERN_START_DATE=2026-01-06              # ISO format YYYY-MM-DD
TIMEZONE=Asia/Kolkata
HUMAN_APPROVAL_MODE=false
DRY_RUN=false
LOG_LEVEL=INFO
LOG_DIR=logs

# ─── Observability ────────────────────────────────────────────────────────────
DASHBOARD_PORT=5050
DASHBOARD_TOKEN=                          # random string, used as bearer token
